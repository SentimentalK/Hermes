# =============================================================================
# Hermes Cloud Brain — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# === OpenRouter ===
# Get your key at https://openrouter.ai/keys
# Configure Anthropic BYOK in OpenRouter, then set that BYOK key to "Always use this key".
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# === Hermes ===
# API key for Hermes gateway server (used by Open WebUI to connect)
# Generate with: openssl rand -hex 32
HERMES_API_SERVER_KEY=change-me-to-a-strong-random-string

# === Open WebUI ===
# Internal secret for session signing
# Generate with: openssl rand -hex 16
OPENWEBUI_SECRET_KEY=change-me-random-32-chars

# === Code-Server ===
# Password for the VS Code web IDE
CODE_SERVER_PASSWORD=change-me-strong-password

# === Caddy Basic Auth (for Dozzle & Code-Server) ===
# Username for admin services.
# Keep this as "admin" unless you also update the caddy.basic_auth.admin labels
# in docker-compose.yml. Caddy Docker Proxy needs the username in the label key.
CADDY_ADMIN_USER=admin

# Hashed password for Caddy basic_auth
# Generate with:
#   docker run --rm caddy caddy hash-password --plaintext 'your-password-here'
# Then paste the output below (keep the quotes if it contains $ signs)
CADDY_ADMIN_HASH=$2a$14$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === General ===
TZ=America/Toronto
